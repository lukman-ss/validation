{
    "name": "lukman-ss/validation",
    "description": "A lightweight standalone PHP Validation package",
    "type": "library",
    "keywords": [
        "validation",
        "validator",
        "php",
        "standalone"
    ],
    "homepage": "https://github.com/lukman-ss/validation",
    "license": "MIT",
    "authors": [
        {
            "name": "Lukman",
            "email": "lukmanumb1@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Lukman\\Validation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lukman\\Validation\\Test\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
